# AI Resume Screener - Environment Variables
# Copy this to .env and fill in your values

# ── Supabase (Auth + DB) ────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service role key — bypasses RLS for server-side DB writes (required for jobs/results inserts)
# Get it from: Supabase Dashboard → Settings → API → service_role (keep this secret!)
SUPABASE_SERVICE_KEY=your-service-role-key

# ── AI Backend ──────────────────────────────────────────────
# Options: "openai", "nvidia", "claude", "gemini", "ollama"
AI_BACKEND=nvidia

# ── NVIDIA Multi-Model Pipeline (RECOMMENDED) ──────────────
# Gemma 4 31B — premium explanations + LLM scoring
NVIDIA_API_KEY=nvapi-your-gemma-key
# LLaMA Nemotron Embed 1B — high-quality embeddings (optional)
NVIDIA_EMBED_API_KEY=nvapi-your-embed-key
# DeepSeek V3.2 — structured skills extraction
NVIDIA_DEEPSEEK_API_KEY=nvapi-your-deepseek-key

# ── Embedding Backend ──────────────────────────────────────
# Options: "local" (free, sentence-transformers) or "nvidia" (API)
EMBEDDING_BACKEND=local

# ── OpenAI (if using OpenAI backend) ────────────────────────
OPENAI_API_KEY=sk-your-api-key-here

# ── Other Providers (optional) ──────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PPLX_API_KEY=
GROK_API_KEY=

# ── Ollama (if using Ollama backend) ────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
